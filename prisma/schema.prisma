generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"   // change to "mysql" if you are on MySQL
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ── NEW ──────────────────────────────────────────────────────────
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

// ─────────────────────────────────────────────────────────────────
// SCHOOL  (tenant)
// ─────────────────────────────────────────────────────────────────

model School {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  status    SchoolStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Existing relations
  users         User[]
  classes       Class[]
  sections      Section[]
  subjects      Subject[]
  announcements Announcement[]

  // NEW
  attendance    Attendance[]

  @@map("schools")
}

// ─────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  gender    Gender?
  phone     String?
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Existing role-specific profiles
  teacherProfile TeacherProfile?
  studentProfile StudentProfile?
  parentProfile  ParentProfile?

  // NEW — attendance records this user has marked (as teacher/admin)
  markedAttendances Attendance[] @relation("AttendanceMarkedBy")

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────
// TEACHER PROFILE
// ─────────────────────────────────────────────────────────────────

model TeacherProfile {
  id            String    @id @default(cuid())
  employeeCode  String?
  qualification String?
  joiningDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Existing relations
  classTeacherOf Section[]
  subjects       TeacherSubject[]

  @@map("teacher_profiles")
}

// ─────────────────────────────────────────────────────────────────
// STUDENT PROFILE
// ─────────────────────────────────────────────────────────────────

model StudentProfile {
  id          String    @id @default(cuid())
  rollNumber  String?
  admissionNo String?
  dateOfBirth DateTime?
  bloodGroup  String?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id])

  // Existing relations
  parents ParentStudent[]

  // NEW
  attendance Attendance[]

  @@map("student_profiles")
}

// ─────────────────────────────────────────────────────────────────
// PARENT PROFILE
// ─────────────────────────────────────────────────────────────────

model ParentProfile {
  id         String   @id @default(cuid())
  occupation String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  children ParentStudent[]

  @@map("parent_profiles")
}

// ─────────────────────────────────────────────────────────────────
// PARENT <-> STUDENT
// ─────────────────────────────────────────────────────────────────

model ParentStudent {
  id       String  @id @default(cuid())
  relation String?

  parentProfileId  String
  parentProfile    ParentProfile  @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)

  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([parentProfileId, studentProfileId])
  @@map("parent_students")
}

// ─────────────────────────────────────────────────────────────────
// CLASS
// ─────────────────────────────────────────────────────────────────

model Class {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  sections Section[]
  subjects Subject[]

  @@unique([schoolId, name])
  @@map("classes")
}

// ─────────────────────────────────────────────────────────────────
// SECTION
// ─────────────────────────────────────────────────────────────────

model Section {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  classTeacherId String?
  classTeacher   TeacherProfile? @relation(fields: [classTeacherId], references: [id])

  // Existing relations
  students StudentProfile[]

  // NEW
  attendance Attendance[]

  @@unique([classId, name])
  @@map("sections")
}

// ─────────────────────────────────────────────────────────────────
// SUBJECT
// ─────────────────────────────────────────────────────────────────

model Subject {
  id        String   @id @default(cuid())
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  teachers TeacherSubject[]

  @@unique([schoolId, classId, name])
  @@map("subjects")
}

// ─────────────────────────────────────────────────────────────────
// TEACHER <-> SUBJECT
// ─────────────────────────────────────────────────────────────────

model TeacherSubject {
  id String @id @default(cuid())

  teacherProfileId String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherProfileId, subjectId])
  @@map("teacher_subjects")
}

// ─────────────────────────────────────────────────────────────────
// ANNOUNCEMENT
// ─────────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

// ─────────────────────────────────────────────────────────────────
// ATTENDANCE  ← NEW
// ─────────────────────────────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date        // DATE only — no time stored
  status    AttendanceStatus @default(PRESENT)
  remarks   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Tenant isolation
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // The student whose attendance this is
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  // The section context (needed for bulk section-day queries)
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  // The teacher/admin who marked this record
  markedById String
  markedBy   User   @relation("AttendanceMarkedBy", fields: [markedById], references: [id], onDelete: Restrict)

  // ── Constraints ─────────────────────────────────────────────
  // One attendance record per student per day (daily attendance)
  @@unique([studentProfileId, date])

  // ── Indexes for common query patterns ───────────────────────
  // 1. "Show all attendance for section X on date Y" (marking page)
  @@index([sectionId, date])

  // 2. "Show attendance for school X on date Y" (admin overview)
  @@index([schoolId, date])

  // 3. "Show attendance history for student X" (student/parent view)
  @@index([studentProfileId])

  // 4. "Show all records marked by teacher X"
  @@index([markedById])

  @@map("attendance")
}
