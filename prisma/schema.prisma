generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum ExamType {
  UNIT_TEST
  MID_TERM
  FINAL
  ASSIGNMENT
  PRACTICAL
  OTHER
}

// ── NEW ──────────────────────────────────────────────────────────
enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

// ─────────────────────────────────────────────────────────────────
// SCHOOL
// ─────────────────────────────────────────────────────────────────

model School {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  status    SchoolStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users         User[]
  classes       Class[]
  sections      Section[]
  subjects      Subject[]
  announcements Announcement[]
  attendance    Attendance[]
  exams         Exam[]
  results       Result[]
  periods       Period[] // ← NEW

  @@map("schools")
}

// ─────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  gender    Gender?
  phone     String?
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  teacherProfile    TeacherProfile?
  studentProfile    StudentProfile?
  parentProfile     ParentProfile?
  markedAttendances Attendance[]    @relation("AttendanceMarkedBy")
  createdExams      Exam[]          @relation("ExamCreatedBy")

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────
// TEACHER PROFILE
// ─────────────────────────────────────────────────────────────────

model TeacherProfile {
  id            String    @id @default(cuid())
  employeeCode  String?
  qualification String?
  joiningDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  classTeacherOf Section[]
  subjects       TeacherSubject[]
  periods        Period[] // ← NEW

  @@map("teacher_profiles")
}

// ─────────────────────────────────────────────────────────────────
// STUDENT PROFILE
// ─────────────────────────────────────────────────────────────────

model StudentProfile {
  id          String    @id @default(cuid())
  rollNumber  String?
  admissionNo String?
  dateOfBirth DateTime?
  bloodGroup  String?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id])

  parents    ParentStudent[]
  attendance Attendance[]
  results    Result[]

  @@map("student_profiles")
}

// ─────────────────────────────────────────────────────────────────
// PARENT PROFILE
// ─────────────────────────────────────────────────────────────────

model ParentProfile {
  id         String   @id @default(cuid())
  occupation String?
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  children ParentStudent[]

  @@map("parent_profiles")
}

// ─────────────────────────────────────────────────────────────────
// PARENT <-> STUDENT
// ─────────────────────────────────────────────────────────────────

model ParentStudent {
  id       String  @id @default(cuid())
  relation String?

  parentProfileId  String
  parentProfile    ParentProfile  @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([parentProfileId, studentProfileId])
  @@map("parent_students")
}

// ─────────────────────────────────────────────────────────────────
// CLASS
// ─────────────────────────────────────────────────────────────────

model Class {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  sections Section[]
  subjects Subject[]
  exams    Exam[]

  @@unique([schoolId, name])
  @@map("classes")
}

// ─────────────────────────────────────────────────────────────────
// SECTION
// ─────────────────────────────────────────────────────────────────

model Section {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId  String
  class    Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  classTeacherId String?
  classTeacher   TeacherProfile? @relation(fields: [classTeacherId], references: [id])

  students   StudentProfile[]
  attendance Attendance[]
  periods    Period[] // ← NEW

  @@unique([classId, name])
  @@map("sections")
}

// ─────────────────────────────────────────────────────────────────
// SUBJECT
// ─────────────────────────────────────────────────────────────────

model Subject {
  id        String   @id @default(cuid())
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId  String
  class    Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  teachers TeacherSubject[]
  results  Result[]
  periods  Period[] // ← NEW

  @@unique([schoolId, classId, name])
  @@map("subjects")
}

// ─────────────────────────────────────────────────────────────────
// TEACHER <-> SUBJECT
// ─────────────────────────────────────────────────────────────────

model TeacherSubject {
  id               String         @id @default(cuid())
  teacherProfileId String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherProfileId, subjectId])
  @@map("teacher_subjects")
}

// ─────────────────────────────────────────────────────────────────
// ANNOUNCEMENT
// ─────────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

// ─────────────────────────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  remarks   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  schoolId         String
  school           School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  sectionId        String
  section          Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  markedById       String
  markedBy         User           @relation("AttendanceMarkedBy", fields: [markedById], references: [id], onDelete: Restrict)

  @@unique([studentProfileId, date])
  @@index([sectionId, date])
  @@index([schoolId, date])
  @@index([studentProfileId])
  @@index([markedById])
  @@map("attendance")
}

// ─────────────────────────────────────────────────────────────────
// EXAM
// ─────────────────────────────────────────────────────────────────

model Exam {
  id        String    @id @default(cuid())
  name      String
  examType  ExamType  @default(OTHER)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  schoolId    String
  school      School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId     String
  class       Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User   @relation("ExamCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  results Result[]

  @@index([schoolId])
  @@index([schoolId, classId])
  @@index([schoolId, examType])
  @@map("exams")
}

// ─────────────────────────────────────────────────────────────────
// RESULT
// ─────────────────────────────────────────────────────────────────

model Result {
  id            String   @id @default(cuid())
  marksObtained Float
  maxMarks      Float    @default(100)
  grade         String?
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  schoolId         String
  school           School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  examId           String
  exam             Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examId, studentProfileId, subjectId])
  @@index([examId])
  @@index([studentProfileId])
  @@index([schoolId])
  @@index([subjectId])
  @@index([schoolId, studentProfileId])
  @@map("results")
}

// ─────────────────────────────────────────────────────────────────
// PERIOD  ← NEW
// One record = one slot in a weekly timetable for a section
// ─────────────────────────────────────────────────────────────────

model Period {
  id           String    @id @default(cuid())
  dayOfWeek    DayOfWeek
  periodNumber Int // 1-indexed: 1 = first period of the day
  startTime    String? // "08:00"  (HH:MM, 24-hr, optional)
  endTime      String? // "08:45"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Tenant isolation
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Which section this slot belongs to
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  // Optional: what subject is taught in this slot
  // SetNull so deleting a subject clears the slot (doesn't delete it)
  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  // Optional: which teacher is assigned to this slot
  teacherProfileId String?
  teacherProfile   TeacherProfile? @relation(fields: [teacherProfileId], references: [id], onDelete: SetNull)

  // Constraints: one slot per (section, day, period number)
  @@unique([sectionId, dayOfWeek, periodNumber])
  // Indexes for common queries
  @@index([schoolId])
  @@index([sectionId])
  @@index([teacherProfileId])
  @@map("periods")
}
