generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum ExamType {
  UNIT_TEST
  MID_TERM
  FINAL
  ASSIGNMENT
  PRACTICAL
  OTHER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

// ── NEW ──────────────────────────────────────────────────────────

enum PaymentMode {
  CASH
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  WAIVED
}

// ─────────────────────────────────────────────────────────────────
// SCHOOL
// ─────────────────────────────────────────────────────────────────

model School {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  status    SchoolStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Existing relations
  users         User[]
  classes       Class[]
  sections      Section[]
  subjects      Subject[]
  announcements Announcement[]
  attendance    Attendance[]
  exams         Exam[]
  results       Result[]
  periods       Period[]

  // NEW
  feeCategories FeeCategory[]
  feeStructures FeeStructure[]
  feePayments   FeePayment[]

  @@map("schools")
}

// ─────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  gender    Gender?
  phone     String?
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  teacherProfile      TeacherProfile?
  studentProfile      StudentProfile?
  parentProfile       ParentProfile?
  markedAttendances   Attendance[]         @relation("AttendanceMarkedBy")
  createdExams        Exam[]               @relation("ExamCreatedBy")
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────
// TEACHER PROFILE
// ─────────────────────────────────────────────────────────────────

model TeacherProfile {
  id            String    @id @default(cuid())
  employeeCode  String?
  qualification String?
  joiningDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  classTeacherOf      Section[]
  subjects            TeacherSubject[]
  periods             Period[]
  passwordResetTokens PasswordResetToken[]

  @@map("teacher_profiles")
}

// ─────────────────────────────────────────────────────────────────
// STUDENT PROFILE
// ─────────────────────────────────────────────────────────────────

model StudentProfile {
  id          String    @id @default(cuid())
  rollNumber  String?
  admissionNo String?
  dateOfBirth DateTime?
  bloodGroup  String?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id])

  // Existing relations
  parents    ParentStudent[]
  attendance Attendance[]
  results    Result[]

  // NEW
  feePayments         FeePayment[]
  passwordResetTokens PasswordResetToken[]

  @@map("student_profiles")
}

// ─────────────────────────────────────────────────────────────────
// PARENT PROFILE
// ─────────────────────────────────────────────────────────────────

model ParentProfile {
  id         String   @id @default(cuid())
  occupation String?
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  children            ParentStudent[]
  passwordResetTokens PasswordResetToken[]

  @@map("parent_profiles")
}

// ─────────────────────────────────────────────────────────────────
// PARENT <-> STUDENT
// ─────────────────────────────────────────────────────────────────

model ParentStudent {
  id       String  @id @default(cuid())
  relation String?

  parentProfileId  String
  parentProfile    ParentProfile  @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([parentProfileId, studentProfileId])
  @@map("parent_students")
}

// ─────────────────────────────────────────────────────────────────
// CLASS
// ─────────────────────────────────────────────────────────────────

model Class {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Existing relations
  sections Section[]
  subjects Subject[]
  exams    Exam[]

  // NEW
  feeStructures FeeStructure[]

  @@unique([schoolId, name])
  @@map("classes")
}

// ─────────────────────────────────────────────────────────────────
// SECTION
// ─────────────────────────────────────────────────────────────────

model Section {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId  String
  class    Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  classTeacherId String?
  classTeacher   TeacherProfile? @relation(fields: [classTeacherId], references: [id])

  students   StudentProfile[]
  attendance Attendance[]
  periods    Period[]

  @@unique([classId, name])
  @@map("sections")
}

// ─────────────────────────────────────────────────────────────────
// SUBJECT
// ─────────────────────────────────────────────────────────────────

model Subject {
  id        String   @id @default(cuid())
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId  String
  class    Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  teachers TeacherSubject[]
  results  Result[]
  periods  Period[]

  @@unique([schoolId, classId, name])
  @@map("subjects")
}

// ─────────────────────────────────────────────────────────────────
// TEACHER <-> SUBJECT
// ─────────────────────────────────────────────────────────────────

model TeacherSubject {
  id               String         @id @default(cuid())
  teacherProfileId String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherProfileId, subjectId])
  @@map("teacher_subjects")
}

// ─────────────────────────────────────────────────────────────────
// ANNOUNCEMENT
// ─────────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

// ─────────────────────────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  remarks   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  schoolId         String
  school           School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  sectionId        String
  section          Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  markedById       String
  markedBy         User           @relation("AttendanceMarkedBy", fields: [markedById], references: [id], onDelete: Restrict)

  @@unique([studentProfileId, date])
  @@index([sectionId, date])
  @@index([schoolId, date])
  @@index([studentProfileId])
  @@index([markedById])
  @@map("attendance")
}

// ─────────────────────────────────────────────────────────────────
// EXAM
// ─────────────────────────────────────────────────────────────────

model Exam {
  id        String    @id @default(cuid())
  name      String
  examType  ExamType  @default(OTHER)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  schoolId    String
  school      School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId     String
  class       Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User   @relation("ExamCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  results Result[]

  @@index([schoolId])
  @@index([schoolId, classId])
  @@index([schoolId, examType])
  @@map("exams")
}

// ─────────────────────────────────────────────────────────────────
// RESULT
// ─────────────────────────────────────────────────────────────────

model Result {
  id            String   @id @default(cuid())
  marksObtained Float
  maxMarks      Float    @default(100)
  grade         String?
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  schoolId         String
  school           School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  examId           String
  exam             Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examId, studentProfileId, subjectId])
  @@index([examId])
  @@index([studentProfileId])
  @@index([schoolId])
  @@index([subjectId])
  @@index([schoolId, studentProfileId])
  @@map("results")
}

// ─────────────────────────────────────────────────────────────────
// PERIOD
// ─────────────────────────────────────────────────────────────────

model Period {
  id           String    @id @default(cuid())
  dayOfWeek    DayOfWeek
  periodNumber Int
  startTime    String?
  endTime      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  schoolId         String
  school           School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sectionId        String
  section          Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId        String?
  subject          Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacherProfileId String?
  teacherProfile   TeacherProfile? @relation(fields: [teacherProfileId], references: [id], onDelete: SetNull)

  @@unique([sectionId, dayOfWeek, periodNumber])
  @@index([schoolId])
  @@index([sectionId])
  @@index([teacherProfileId])
  @@map("periods")
}

// ─────────────────────────────────────────────────────────────────
// FEE CATEGORY  ← NEW
// Named buckets that a school defines once and reuses every year
// e.g. "Tuition", "Transport", "Library", "Sports", "Lab"
// ─────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @db.VarChar(64)
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherProfile   TeacherProfile? @relation(fields: [teacherProfileId], references: [id])
  teacherProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id])
  studentProfileId String?
  parentProfile    ParentProfile?  @relation(fields: [parentProfileId], references: [id])
  parentProfileId  String?

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model FeeCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Tenant isolation
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  feeStructures FeeStructure[]

  // Category names must be unique per school
  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("fee_categories")
}

// ─────────────────────────────────────────────────────────────────
// FEE STRUCTURE  ← NEW
// Defines HOW MUCH is owed for a category, by which class,
// in which academic year, and when it is due.
//
// classId = null  →  applies to ALL classes in the school
// classId = set   →  applies to that specific class only
//
// Examples:
//   Tuition | Grade 10 | 2024-25 | ₹12,000 | due 1 Apr
//   Transport | (all)  | 2024-25 | ₹3,000  | due 1 Apr
// ─────────────────────────────────────────────────────────────────

model FeeStructure {
  id           String    @id @default(cuid())
  amount       Float // e.g. 12000.00
  dueDate      DateTime? // when payment is expected
  academicYear String // e.g. "2024-25"
  description  String? // optional note
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Tenant isolation
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Fee category (e.g. Tuition)
  feeCategoryId String
  feeCategory   FeeCategory @relation(fields: [feeCategoryId], references: [id], onDelete: Cascade)

  // Optional: if null → applies to all classes
  classId String?
  class   Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  payments FeePayment[]

  // ── Indexes ───────────────────────────────────────────────────
  // "All structures for school X in year Y"
  @@index([schoolId, academicYear])
  // "All structures for a category"
  @@index([schoolId, feeCategoryId])
  // "All structures for a class"
  @@index([schoolId, classId])
  @@map("fee_structures")
}

// ─────────────────────────────────────────────────────────────────
// FEE PAYMENT  ← NEW
// One record per student per fee structure.
// Tracks the cumulative amount paid and current status.
//
// Flow:
//   Student owes ₹12,000 (FeeStructure.amount)
//   Admin records ₹5,000 → status = PARTIAL, amountPaid = 5000
//   Admin records ₹7,000 → status = PAID,    amountPaid = 12000
//   Or:
//   Admin waives ₹12,000 → status = WAIVED
//
// outstanding = feeStructure.amount - amountPaid - waivedAmount
// ─────────────────────────────────────────────────────────────────

model FeePayment {
  id             String        @id @default(cuid())
  amountPaid     Float         @default(0) // cumulative total paid
  waivedAmount   Float         @default(0) // amount waived by admin
  paymentDate    DateTime? // date of most recent payment
  paymentMode    PaymentMode   @default(CASH)
  status         PaymentStatus @default(PENDING)
  transactionRef String? // bank ref / receipt no.
  remarks        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Tenant isolation
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Which student
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  // Which fee obligation
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  // ── Constraints ───────────────────────────────────────────────
  // One payment record per student per fee structure
  // (we update this record as payments come in, not create new rows)
  @@unique([studentProfileId, feeStructureId])
  // ── Indexes ───────────────────────────────────────────────────
  // "All payments for school X" (admin overview)
  @@index([schoolId])
  // "All payments for student X" (student fee ledger)
  @@index([studentProfileId])
  // "All payments for structure X" (fee-wise collection report)
  @@index([feeStructureId])
  // "All PENDING/PARTIAL payments for school X" (defaulters list)
  @@index([schoolId, status])
  // "All payments for school X in year Y" (annual report)
  // NOTE: academicYear comes from feeStructure — query via join
  @@index([schoolId, paymentDate])
  @@map("fee_payments")
}
